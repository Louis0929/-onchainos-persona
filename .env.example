# OKX Web3 API credentials — get from https://www.okx.com/account/my-api
# Option A: API Key auth (recommended)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Option B: JWT / Access Token auth
OKX_ACCESS_TOKEN=

# Optional: Custom OKX base URL (default: https://web3.okx.com)
# OKX_BASE_URL=

# Optional: Custom server port (default: 3102)
# PORT=3102
